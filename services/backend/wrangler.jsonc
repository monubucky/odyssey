{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "odyssey-backend",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "odyssey",
      "database_id": "local-odyssey"
    }
  ]
}